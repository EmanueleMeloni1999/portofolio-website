# ═══════════════════════════════════════════════════════════
# SHOWREEL AUTHENTICATION - Environment Variables
# ═══════════════════════════════════════════════════════════
#
# Queste variabili devono essere configurate su Vercel Dashboard
# (Settings → Environment Variables)
#

# Hash SHA-256 della password per la showreel
# Generare con: node generate-password-hash.js "TuaPasswordQui"
SHOWREEL_PASSWORD_HASH=your_password_hash_here

# ID del video YouTube (la parte dopo watch?v=)
# Esempio: https://www.youtube.com/watch?v=yk6dA3tnU8g → yk6dA3tnU8g
SHOWREEL_VIDEO_ID=yk6dA3tnU8g

# ═══════════════════════════════════════════════════════════
# Note di sicurezza:
# - Non committare mai il file .env nel repository
# - L'hash della password è irreversibile (one-way)
# - Usa password complesse (min 12 caratteri, lettere+numeri+simboli)
# ═══════════════════════════════════════════════════════════
